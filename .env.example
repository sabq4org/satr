# قاعدة البيانات (مطلوبة)
# للسحابة: استخدم Neon
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require

# أو محلياً:
# DATABASE_URL=postgres://USER@localhost:5432/satr

# OpenAI (اختياري - بدونه يستخدم Mock)
OPENAI_API_KEY=

# وضع الـ AI: true = mock محلي (أوفلاين)، false = OpenAI الحقيقي
USE_AI_MOCK=true

# Cloudinary (اختياري للصور)
CLOUDINARY_URL=
