# ============================================
# سطر — متغيرات البيئة
# ============================================

# قاعدة البيانات (مطلوبة)
# للسحابة: استخدم Neon
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require

# أو محلياً:
# DATABASE_URL=postgres://USER@localhost:5432/satr

# ============================================
# الذكاء الاصطناعي
# ============================================

# اختر المحرك: ollama (محلي) | openai (سحابي) | mock (افتراضي بدون AI)
AI_ENGINE=ollama

# Ollama (محلي)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:14b

# OpenAI (سحابي)
OPENAI_API_KEY=

# Mock fallback
USE_AI_MOCK=true

# ============================================
# المصادقة (مطلوبة لـ /admin)
# ============================================

# كلمة سر لوحة التحرير - غيّرها في الإنتاج!
ADMIN_PASSWORD=satr-admin

# سر التوقيع للجلسات (مطلوب في الإنتاج)
AUTH_SECRET=change-me-to-a-long-random-string

# ============================================
# الصور والميديا (اختياري)
# ============================================
CLOUDINARY_URL=

# ============================================
# الإنتاج
# ============================================
NEXT_PUBLIC_SITE_URL=https://satr.sa
